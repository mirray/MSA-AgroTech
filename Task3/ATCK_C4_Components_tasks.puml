@startuml Архитектура_АвтоТехноСвиноКомплекс_v1_Tasks
!include <C4/C4_Component>
ContainerQueue_Ext(data_hub, "MQTT broker")
Boundary(internal_services, "Tasks management"){
        ContainerDb(tasks_db, "Tasks DB")
        Container_Boundary(tasks, "Tasks management"){
            Component(tasks_historical, "MQTT Consumer") 
            Rel_D(data_hub, tasks_historical,"topic: tasks")
            Rel_D(tasks_historical, tasks_db, "structured data")
        }
        ContainerDb(tasks_db, "Tasks DB")
        Container_Boundary(tasks_api, "Tasks: Api Service"){
            Component(tasks_qh, "Query handler")
            Rel_D(tasks_db, tasks_qh, "collects tasks")
            Component(tasks_ch, "Command handler")
            Rel_U(tasks_ch, tasks_db, "update task status")
            Component(tasks_cache, "Cache")   
            Rel_L(tasks_qh, tasks_cache, "cached data")
            Component(tasks_controller, "Rest API Controller")
            Rel_U(tasks_controller, tasks_qh, "Send request")
            Rel_U(tasks_controller, tasks_ch, "Send command")
            Rel_D(tasks_cache, tasks_controller, "get data")
        }       
    }
    Container_Ext(api, "API - Gateway")
    BiRel_D(tasks_controller, api, "tasks", "Rest API")    
@enduml