@startuml Архитектура_АвтоТехноСвиноКомплекс_v1_Альтернативное_Решение
!include <C4/C4_Component>

System_Boundary(atck_agent, "Agent"){
    ContainerQueue(broker, "MQTT broker", "EMQX")
    Boundary(b_video, "Video"){
        Container_Boundary(video, "Video analysis"){
            Component(ip_cameras, "IP-Cameras")
            Component(ai, "Edge Device for video analysis", "OpenCV")
            Rel(ip_cameras, ai, "video stream", "RTSP")
            Rel(ai, broker, "send events", "MQTT")
        }
        Person(duty_operator, "Duty Operator")
        Container_Boundary(notification, "Notifications"){
            Component(notification_service, "Notification Service")
            Rel(ai, notification_service, "send notification")
            Rel(notification_service, duty_operator, "Recieves notification")
        }
    }
    Lay_L(broker, b_video)
    Container_Boundary(iot, "IOT data collecting"){
        Component(iot_devices, "IoT sensors")
        Component(rfid_scanners, "RFID-scaners")
        Rel(iot_devices, broker, "sensors data", "MQTT")
        Rel(rfid_scanners, broker, "RFID data", "MQTT")
    } 

    ContainerQueue(event_broker, "Event broker", "Kafka")
    
    Container_Boundary(data, "Data Lake" ){
            ComponentDb(data_iot, "Data from IoT sensors", "TimescaleDB")
            Component(data_aggregated, "Manage aggregated data", "Python")
            Rel(broker, data_iot, "raw data from Iot sensors", "MQTT")
            Rel(data_aggregated, data_iot, "manage aggregated views", "Psql")
            Rel(data_iot, data_aggregated, "request aggregated data", "Psql")
        }

    Container_Boundary(iot_management, "Manage IoT devices"){
            Component(iot_service, "Service: Analyse data from Iot sensors")
            ComponentDb(eventlog_iot, "Event Log", "PostgresQL")
            Rel(iot_service, data_aggregated, "request data", "psql")
            Rel(iot_service, broker, "commands for IoT device", "MQTT")
            Rel(iot_service, event_broker, "tasks for people", "JSON")
            Rel(iot_service, eventlog_iot, "Stores data in Event Log", "psql")
        } 
    
    Container_Boundary(prediction, "Prediction data service"){
            Component(prediction_service, "Service: Analyse historical data")
            ComponentDb(eventlog_prediction, "Event Log + historical data storage", "PostgresQL")
            Rel(prediction_service, data_aggregated, "request data", "psql")
            Rel(prediction_service, event_broker, "commands for erp (buy food for pigs)", "JSON")
            Rel(prediction_service, eventlog_prediction, "Stores data", "psql")
        }        
    Container_Boundary(pigs, "Pigs management"){
            Component(pigs_service, "Service: pigs health analysis & counter")
            ComponentDb(eventlog_pigs, "Event Log + historical data storage", "PostgresQL")
            Rel(pigs_service, data_aggregated, "request data", "psql")
            Rel(pigs_service, event_broker, "pigs data", "JSON")
            Rel(pigs_service, eventlog_pigs, "Stores data", "psql")
        }
        
    Container_Boundary(tasks, "Tasks management"){
            Component(tasks_service, "Service: task management", "Spread tasks across people")
            ComponentDb(eventlog_tasks, "Event Log + People data local storage", "PostgresQL")
            Rel(event_broker, tasks_service, "get commands for people", "JSON")
            Rel(event_broker, tasks_service, "get results of command executions", "JSON")
            Rel(event_broker, tasks_service, "get people data (ERP)", "JSON")
            Rel(tasks_service, event_broker, "send personificated commands", "JSON")
            Rel(tasks_service, eventlog_tasks, "Stores data", "psql")
        }
    Boundary(b_ui, "UI"){
        Boundary(users, "Users"){
            Person(operator, "Operator")
            Person(vet, "Vet")
        }
        Component(app, "Mobile or Web application")
        Rel(app, operator, "Uses: tasks")
        Rel(app, vet, "Uses: health data for pigs")
        Component(bff_service, "Back for front service", "ETL")
        Component(api_gateaway, "API Gateaway: Provides data for app", "REST Api + SSE (for notifications)")
        ComponentDb(eventlog_api_gateaway, "Event Log + local storage", "PostgresQL")
        BiRel(bff_service, eventlog_api_gateaway, "store/read data", "psql")
        BiRel(bff_service, event_broker, "send/receive commands", "JSON")
        BiRel(api_gateaway, bff_service, "send/receive data")
        BiRel(api_gateaway, app, "send data", "SSE")
        Rel(api_gateaway, app, "receive data", "Rest API")
    }
    
    Container_Boundary(erp_sync, "ERP Sync gate"){
            System_Ext(erp, "ERP - system")
            Component(erp_sync_service, "Sync service for ERP", "send/receive data from ERP")
            ComponentDb(eventlog_erp_sync, "Event Log + local storage", "PostgresQL")
            Rel(erp_sync_service, eventlog_erp_sync, "Stores data", "psql")
            BiRel(erp_sync_service, event_broker, "send ERP-data", "JSON")
            BiRel(erp, erp_sync_service, "Sync data", "Rest Api")
        }
}

System_Boundary(atck_server, "Server"){

    System_Ext(analytic_module, "Analytic Module")
    
    Container_Boundary(analytic_module_sync, "Analytic Sync gate"){
            System_Ext(analytic_module, "Analytic Module")
            Component(analytic_module_sync_service, "Sync service for Analytic Module", "send/receive metrics data")
            ComponentDb(eventlog_analytic_module_sync, "Event Log + local storage", "PostgresQL")
            Rel(analytic_module_sync_service, eventlog_analytic_module_sync, "Stores data", "psql")
            Rel(data_aggregated, analytic_module_sync_service, "send metrics data")
            Rel(analytic_module_sync_service, analytic_module ,"send metrics data")
        }
    Container_Boundary(metrics, "Manage metrics"){
        Component(metrics_service, "Service for manage metrics")
        Rel(metrics_service, data_aggregated, "create new metrics", "Psql")
        Rel(data_aggregated, metrics_service, "request metrics data", "Psql")
    }
    Container(ui_online, "Online Mobile or Web application")
    Person(analytic, "Analytic")
    Rel(analytic, ui_online, "Uses: metrics")
    BiRel(ui_online, metrics_service, "get metrics data and manage metrics")
    
}

@enduml