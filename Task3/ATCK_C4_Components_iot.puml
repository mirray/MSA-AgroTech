@startuml Архитектура_АвтоТехноСвиноКомплекс_v1_Iot
!include <C4/C4_Component>

ContainerQueue_Ext(data_hub, "MQTT broker")
Container_Boundary(iot_auto_management, "IOT auto-manage"){
    Component(iot_auto_management_service_p, "MQTT Producer")
    Component(iot_auto_management_service_c, "MQTT Consumer")
    Component(iot_auto_management_service, "Analyze IoT Data", "PySpark")
    Rel_D(data_hub, iot_auto_management_service_c, "topic:sensors", "MQTT")
    Rel_D(iot_auto_management_service_c, iot_auto_management_service, "sensors data")
    Rel_U(iot_auto_management_service, iot_auto_management_service_p, "commands")
    Rel_U(iot_auto_management_service_p, data_hub, "topic:commands","MQTT")
    Lay_R(iot_auto_management_service_c, iot_auto_management_service_p)
}

Container_Boundary(iot_health_check, "IOT health check"){
    Component(iot_health_check_service_p, "MQTT Producer")
    Component(iot_health_check_service_c, "MQTT Consumer")
    Component(iot_health_check_service, "IOT health check", "PySpark")
    Rel_D(data_hub, iot_health_check_service_c, "topic:sensors","MQTT")
    Rel_U(iot_health_check_service_p, data_hub, "topic:tasks","MQTT")
    Rel_D(iot_health_check_service_c, iot_health_check_service, "sensors data")
    Rel_U(iot_health_check_service, iot_health_check_service_p, "tasks")
}
    
@enduml