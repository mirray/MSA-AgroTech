@startuml Архитектура_АвтоТехноСвиноКомплекс_v1_Альтернативное_Решение
!include <C4/C4_Container>
Person(duty_operator, "Дежурный оператор")
Person(operator, "Оператор")
Person(analytic, "Аналитик")
Person(vet, "Ветеринар")

Container(ui, "Мобильное или веб приложение")

System_Boundary(atck_agent, "АвтоТехноСвиноКомплекс - Агент") {
    Container(video, "Сервис видеоанализа")
    Container(iot, "Сервис умных устройств")
    Container(notification, "Сервис оповещения")
    Container(broker, "Брокер сообщений")
    Rel(video, broker, "Публикует события для оповещения")
    Rel(iot, broker, "Передает данные с датчиков")
    Rel(broker, iot, "Передает команды устройствам")
    Rel(broker, notification, "Передает события для оповещения")

    Container(water, "Сервис управления поилками")
    Container(food, "Сервис управления кормушками")
    Container(water_filter, "Сервис управления фильтрами воды")
    Container(food_supply, "Сервис прогнозирования расхода корма")
    Container(pigs, "Сервис учета свиней")
    Container(tasks, "Сервис задач")

    Rel(broker, water, "Данные с датчиков поилок")
    Rel(water, broker, "Команды для поилок")
    Rel(water, broker, "Задачи на обслуживание")

    Rel(broker, food, "Данные с датчиков кормушек")
    Rel(food, broker, "Команды для кормушек")
    Rel(food, broker, "Задачи на обслуживание")

    Rel(broker, water_filter, "Данные с датчиков фильтров воды")
    Rel(water_filter, broker, "Задачи на обслуживание")

    Rel(broker, food_supply, "Данные с датчиков кормушек")
    Rel(food_supply, broker, "Заявки на закупку корма")
    Rel(food_supply, broker, "Данные по расходованию корма")

    Rel(broker, pigs, "Данные с RFID-сканеров")
    Rel(broker, pigs, "Данные с поведении")
    Rel(pigs, broker, "Данные о состоянии")

    Rel(broker, tasks, "Задачи на обслуживание")
    Rel(broker, tasks, "Результат выполнения задач")
    Rel(tasks, broker, "Распределение задач на обслуживание")    
}
System_Boundary(atck_server, "АвтоТехноСвиноКомплекс - Сервер"){
    Container(broker_server, "Брокер сообщений")
    Container(metrics, "Сервис метрик")
   
    
    Rel(broker_server, metrics, "Структурированные данные от сервисов")
    Rel(broker_server, metrics, "Данные с датчиков")
    Rel(broker_server, metrics, "Кастомные метрики")
    Rel(metrics, broker_server, "Расчет метрик")

}

Rel(broker_server, ui, "Данные для отображения")
Rel(ui, broker_server, "Данные от пользователей")
Rel(broker, ui, "Данные для отображения")
Rel(ui, broker, "Данные от пользователей")

Rel(broker, broker_server, "Синхронизирует данные")

Rel(notification, duty_operator, "Получает уведомления")
Rel(ui, operator, "Использует: задачи на обслуживание")
Rel(ui, vet, "Использует: данные о животных")
Rel(analytic, ui, "Использует: метрики")

System_Ext(analytic_module, "Аналитический модуль")
System_Ext(erp, "ERP - система")

Rel(metrics, analytic_module, "Передает данные метрик")
Rel(food_supply, erp, "Отправляет заявки на закупку кормов")
@enduml