@startuml agrotech_atck_intergration

!include <C4/C4_Container>
' === Участники ===
Person(директор, "Директор хозяйства", "Управление через веб-портал")
Person(агроном, "Агроном", "Использует мобильное приложение")
Person(тепличник, "Тепличный комплекс", "Управление теплицами")
Person(механик, "Механик", "Мониторинг техники")
Person(аналитик, "Аналитик", "Работа с BI-системой")

System_Boundary(платформа, "АгроПром Х - Цифровая платформа") {
    Container(веб_портал, "Веб-портал", "React", "Управление хозяйством")
    Container(мобильное_приложение, "Мобильное приложение", "Flutter", "Полевые работы")
    ContainerDb(erp, "ERP система (1С:Агро)", "1С", "Финансы, склад, кадры")
    
    Container_Boundary(тепличные_системы, "Тепличные комплексы") {
        Container(scada, "SCADA система", "Ignition", "Управление климатом")
        Container(тепличные_датчики, "Тепличные датчики", "Python", "Микроклимат, полив")
        Container(автополив, "Система автополива", "C++", "Управление орошением")
    }
    
    Container(kafka, "Брокер сообщений", "Apache Kafka", "Шина данных")
    
    Container_Boundary(iot_платформа, "IoT платформа") {
        Container(iot_шлюз, "IoT шлюз", "Node-RED", "Сбор данных с полей")
        Container(tsdb, "База временных рядов", "TimescaleDB", "Данные датчиков")
        Container(трекер_техники, "Трекер техники", "Java", "Мониторинг транспорта")
    }
    
    Container_Boundary(полевые_данные, "Данные с полей") {
        Container(метео_данные, "Метеостанции", "Python", "Погодные условия")
        Container(почва, "Датчики почвы", "Python", "Влажность, состав")
        Container(урожайность, "Мониторинг урожая", "Python", "Камера+ИИ на технике")
    }
    
    Container_Boundary(управление_техникой, "Управление техникой") {
        Container(планировщик, "Планировщик заданий", "Kotlin", "Распределение работ")
        Container(мониторинг_гсм, "Мониторинг ГСМ", "Go", "Контроль топлива")
        Container(диагностика, "Диагностика", "C#", "Состояние техники")
    }
    
    Container_Boundary(данные, "Хранилища данных") {
        ContainerDb(data_lake, "Data Lake", "MinIO", "Сырые данные (S3-совместимое)")
        ContainerDb(dwh, "Data Warehouse", "ClickHouse", "Структурированные данные")
    }
    
    Container(bi, "BI система", "Power BI", "Отчеты и визуализация")
    Container(аналитика, "Аналитический модуль", "Python+Spark", "Анализ эффективности")
}

' === Взаимосвязи ===
Rel_D(директор, веб_портал, "Использует")
Rel(агроном, мобильное_приложение, "Использует")
Rel(тепличник, scada, "Управляет")
Rel(механик, трекер_техники, "Мониторит")
Rel(аналитик, bi, "Анализирует")

' Центральная Kafka
Rel(iot_шлюз, kafka, "Публикует данные", "Kafka Protocol")
Rel(тепличные_датчики, kafka, "Публикует данные", "MQTT->Kafka")
Rel(трекер_техники, kafka, "Публикует позиции", "Kafka Protocol")
Rel(kafka, data_lake, "Сырые данные", "Kafka Connect+S3")
Rel(kafka, dwh, "Трансформированные данные", "ETL+Airflow")

' Тепличные системы
Rel(scada, kafka, "Публикует климат-данные", "OPC UA->Kafka")
Rel(автополив, scada, "Получает команды", "Modbus TCP")
Rel(тепличные_датчики, scada, "Передает данные", "LoRaWAN")

' Полевые данные
Rel(метео_данные, iot_шлюз, "Передает данные", "LoRaWAN")
Rel(почва, iot_шлюз, "Передает данные", "LoRaWAN")
Rel(урожайность, iot_шлюз, "Передает данные", "4G")

' Управление техникой
Rel(kafka, планировщик, "Поток задач", "Kafka Protocol")
Rel(мониторинг_гсм, dwh, "Сохраняет данные", "ETL")
Rel(диагностика, erp, "Передает данные о ремонтах", "REST API")

' Аналитика
Rel(data_lake, аналитика, "Доступ к сырым данным", "Spark")
Rel(dwh, аналитика, "Доступ к структурированным данным", "SQL")
Rel(аналитика, bi, "Передает отчеты", "ODBC")
Rel(аналитика, веб_портал, "Формирует рекомендации", "WebSocket")

' ERP интеграция
Rel(веб_портал, erp, "Синхронизация данных", "REST API")
Rel(erp, dwh, "Бизнес-данные", "ETL")
Rel(мобильное_приложение, kafka, "Полевые отчеты", "Kafka Protocol")

' ATCK

System_Boundary(atck, "АвтоТехноСвиноКомплекс "){
    Person(duty_operator, "Duty Operator")
    ContainerQueue(data_hub, "MQTT broker", "Store data, provide communication between containers")
    Boundary(video_b, "AI Video analysis"){
        Container(video, "Events: Video analysis", "Analyze pigs-behavior from cameras and recognize dangerous events")
        Rel(video, data_hub, "events")
        Rel_U(video, duty_operator, "notifications")
    }
    Boundary(iot_b, "IoT Auto Management"){
         Container(iot_auto_management, "IOT auto-manage", "Analyze data from sensors and send commands to devices")
         Rel(iot_auto_management, data_hub, "commands")
         Rel(data_hub, iot_auto_management, "data")
         Container(iot_health_check, "IOT health check", "Check if Iot sensors or devices require human help (clean, replace, repair and so on)")
         Rel_U(iot_health_check, data_hub, "tasks")
         Rel(data_hub, iot_health_check, "data")
    }
    System_Ext(iot_sensors, "IoT sensors")
    System_Ext(iot_devices, "IoT devices")
    System_Ext(rfid_scanners, "RFID-scanners")
    Rel_D(iot_sensors, data_hub, "sensors data")
    Rel_D(rfid_scanners, data_hub, "rfid data")
    Rel_L(data_hub, iot_devices, "commands")

    ContainerQueue(data_hub_server, "MQTT broker", "Store data from IoT devices")
    BiRel_R(data_hub, data_hub_server, "sync data", "Unstable network")
    
    Boundary(b_pigs, "Pigs health monitoring"){
        Container(pigs, "Pigs management", "Checks pigs status and health")
        Rel_D(data_hub_server, pigs, "data from RFID-sensors & events")
        ContainerDb(pigs_db, "Pigs DB")
        BiRel_D(pigs, pigs_db, "uses")
        Container(pigs_api, "Pigs: Api Service")
        Rel_D(pigs_db, pigs_api, "collects pigs profiles")
    }
    Boundary(internal_services, "Tasks management"){
        Container(tasks, "Tasks management", "Manages tasks for operators")
        Rel_D(data_hub_server, tasks, "tasks")
        ContainerDb(tasks_db, "Tasks DB")
        BiRel_D(tasks, tasks_db, "uses")
        Container(tasks_api, "Tasks: Api Service")
        BiRel_D(tasks_db, tasks_api, "Manage tasks")       
        
    }
    ContainerDb(analytic_db, "Data lake", "store raw data from all Iot devices")
    Boundary(analysis_internal, "Internal Analytic Services"){
            Container(metrics_management, "Metrics: Api Service", "Create, modify, remove metrics")
            ContainerDb(metrics_management_db, "Metrics storage", "Store metrics configurations")
            BiRel_U(metrics_management, metrics_management_db, "uses")
            Container(analytic_module_sync, "Analytic Sync gate", "Send metrics data to external analytics module")   
           Rel_D(analytic_db, analytic_module_sync, "collect aggregated data")
            Rel(analytic_module_sync, аналитика ,"aggregated data")
            
            Rel_R(data_hub_server, analytic_db, "store")
            Container(metrics_manager, "Metrics manager", "Creates aggregated views") 
            Rel_D(metrics_manager, analytic_db, "aggregated views", "CRUD")
            Rel_D(metrics_manager, metrics_management_db, "requests metrics config")                
    }
    Boundary(b_supply, "Food Supply"){
            Container(supply, "Supply management", "Analyzes amount of food, and request to buy more")
            Rel_D(data_hub_server, supply, "data from feeders sensors")
            ContainerDb(supply_db, "Supply DB")
            BiRel_D(supply, supply_db, "uses")
            Container(erp_sync, "ERP Sync gate", "Sync data with ERP")
            Rel_D(supply_db, erp_sync, "Collect requests")  
            Rel_R(erp_sync, erp, "send requests")
        }
    Boundary(b_billing, "Billing service") {
     
       Container(balance_checker, "Balance Checker Service", "", "Check balance and notify tenant if it's low or zero")
        Container(tariffication, "Tariffication Service", "","Calculates current usage and reduce balance")
        ContainerDb(billing_db, "Billing DB")
        Container(billing_api, "Billing Api Service")
        System_Ext(payment_system, "Payment System Api")
        Rel(analytic_db, tariffication, "collect usage statistic")
        Rel(tariffication, billing_db, "uses")
        Rel(billing_db, balance_checker, "balance")
        Rel_D(balance_checker, директор, "notify", "SMTP, SMS")
        BiRel(billing_api, payment_system, "payment")
        Rel_L(billing_api, billing_db, "increase balance")
        
    }

    Container(api, "API - Gateway", "Authentification + Authorization, Redis cache")       
    BiRel_D(tasks_api, api, "uses")
    BiRel_D(pigs_api, api, "uses")
    BiRel_D(metrics_management, api, "uses")
    BiRel_D(billing_api, api, "uses")
    Boundary(ui_b, "User interface"){       
        Container(ui, "Mobile or Web application")
        Person(operator, "Operator")
        
        Person(vet, "Vet")
        
        Rel_D(директор, ui, "Make payments")
        BiRel_D(ui, operator, "Uses: tasks")
        BiRel_D(ui, vet, "Uses: health data for pigs")
        BiRel_D(ui, аналитик, "Uses: metrics")
        BiRel_D(api,ui, "uses")
        
        Container(docs, "Api Documentation Web Portal", "Rapidoc")
    } 
}
@enduml