@startuml Архитектура_АвтоТехноСвиноКомплекс_v1_Альтернативное_Решение
!include <C4/C4_Context>

' === Участники ===
Person(duty_operator, "Дежурный оператор")
Person_Ext(technican, "Техник умных систем")
Person_Ext(cv_technican, "Техник видеонаблюдения")
Person(operator, "Оператор")
Person_Ext(vet, "Ветеринар")
Person(admin, "Администратор системы")

System_Ext(analytic, "Аналитический модуль")
System_Ext(erp, "ERP - система")

System(atck, "АвтоТехноСвиноКомплекс")

Rel(atck, duty_operator, "Оповещение","","Уведомления о поведении животных")
Rel(atck, operator, "Получает", "" ,"Задачи на ежедневное обслуживание кормушек и поилок")
Rel(vet, atck, "Запрашивает", "", "Данные о здоровье животных")
Rel(atck, analytic, "Отправляет", "", "метрики")
Rel(atck, erp, "Отправляет", "", "данные о поголовье свиней")
Rel(atck, erp, "Отправляет", "", "заявки на закупку кормов")
Rel(admin, atck, "Вносит", "", "данные о метриках, данные об автоматизированных устройствах, данные о камерах")
Rel(atck, cv_technican, "Получает", "" ,"Задачи на обслуживание камер")
Rel(atck, technican, "Получает", "" ,"Задачи на установку/ремонт автоматизированных устройств")
@enduml